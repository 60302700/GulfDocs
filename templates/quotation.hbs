<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Professional Quotation - GCC Standard</title>
    <style>
        :root {
            --primary: #0f172a;
            --secondary: #64748b;
            --accent: #2563eb;
            --border: #e2e8f0;
            --bg-light: #f8fafc;
            --success: #059669;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', -apple-system, system-ui, sans-serif;
        }

        body {
            background: #ffffff;
            color: var(--primary);
            line-height: 1.5;
        }

        .quote-wrapper {
            width: 100%;
            background: #fff;
        }

        .header {
            padding: 40px;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            background: var(--primary);
            color: white;
        }

        .brand h1 {
            font-size: 28px;
            font-weight: 800;
            letter-spacing: -1px;
            margin-bottom: 5px;
        }

        .brand p {
            font-size: 13px;
            opacity: 0.8;
        }

        .quote-meta {
            text-align: right;
        }

        .quote-meta h2 {
            font-size: 32px;
            font-weight: 300;
            letter-spacing: 2px;
            margin-bottom: 10px;
        }

        .meta-box {
            font-size: 13px;
            display: grid;
            grid-template-columns: auto auto;
            gap: 5px 15px;
            justify-content: end;
        }

        .meta-label {
            opacity: 0.7;
            font-weight: 400;
        }

        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            padding: 30px 40px;
            background: var(--bg-light);
        }

        .info-card {
            background: white;
            padding: 20px;
            border-radius: 12px;
            border: 1px solid var(--border);
        }

        .info-card h3 {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--accent);
            margin-bottom: 12px;
        }

        .card-content {
            font-size: 14px;
        }

        .card-content b {
            display: block;
            margin-bottom: 4px;
            font-size: 16px;
        }

        .items-section {
            padding: 30px 40px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            text-align: left;
            padding: 15px;
            font-size: 12px;
            color: var(--secondary);
            border-bottom: 2px solid var(--primary);
            text-transform: uppercase;
        }

        td {
            padding: 20px 15px;
            border-bottom: 1px solid var(--border);
            font-size: 14px;
            vertical-align: top;
        }

        .item-desc b {
            display: block;
            color: var(--primary);
            margin-bottom: 4px;
        }

        .item-desc small {
            color: var(--secondary);
            line-height: 1.4;
        }

        .bottom-grid {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            padding: 0 40px 40px;
            gap: 40px;
        }

        .conditions-box {
            font-size: 13px;
            color: var(--secondary);
        }

        .conditions-box h4 {
            color: var(--primary);
            margin-bottom: 10px;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .conditions-box ul {
            padding-left: 18px;
        }

        .conditions-box li {
            margin-bottom: 6px;
        }

        .totals-table {
            width: 100%;
        }

        .totals-table td {
            border: none;
            padding: 8px 0;
            text-align: right;
        }

        .totals-table td:first-child {
            text-align: left;
            color: var(--secondary);
        }

        .grand-total {
            border-top: 2px solid var(--primary) !important;
            padding-top: 15px !important;
            font-size: 22px !important;
            font-weight: 800;
            color: var(--primary);
        }

        .approval-section {
            margin: 0 40px 40px;
            padding: 30px;
            border: 2px dashed var(--border);
            border-radius: 16px;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }

        .client-sign-box {
            width: 250px;
            text-align: center;
        }

        .sign-line {
            border-top: 1px solid var(--primary);
            margin-top: 50px;
            padding-top: 8px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .contact-footer {
            text-align: center;
            padding: 20px;
            font-size: 12px;
            color: var(--secondary);
            border-top: 1px solid var(--border);
        }

        @media (max-width: 768px) {

            .header,
            .info-grid,
            .bottom-grid,
            .approval-section {
                grid-template-columns: 1fr;
                flex-direction: column;
            }

            .quote-meta {
                text-align: left;
                margin-top: 20px;
            }

            .totals-table {
                width: 100%;
            }
        }
    </style>
</head>

<body>

    <div class="quote-wrapper">
        <!-- HEADER -->
        <header class="header">
            <div class="brand">
                <h1>{{company.name}}</h1>
                <p>TRN: {{company.trn}}</p>
                <p>{{company.city}}, {{company.country}}</p>
                <p>{{company.email}} | {{company.phone}}</p>
            </div>
            <div class="quote-meta">
                <h2>QUOTATION</h2>
                <div class="meta-box">
                    <span class="meta-label">Quote #</span> <span><b>{{quoteID}}</b></span>
                    <span class="meta-label">Date</span> <span>{{date}}</span>
                    <span class="meta-label">Valid Until</span> <span>{{expiryDate}}</span>
                    <span class="meta-label">Prepared By</span> <span>{{preparedBy}}</span>
                </div>
            </div>
        </header>

        <!-- INFO CARDS -->
        <section class="info-grid">
            <div class="info-card">
                <h3>Quotation For</h3>
                <div class="card-content">
                    <b>{{client.companyName}}</b>
                    {{client.contactPerson}}<br>
                    {{client.address}}<br>
                    {{client.phone}}
                </div>
            </div>
            <div class="info-card">
                <h3>Project / Reference</h3>
                <div class="card-content">
                    <p><b>{{project.name}}</b></p>
                    <p style="color: var(--secondary); margin-top: 8px;">
                        Estimated Timeline: {{project.duration}}<br>
                        Payment Terms: {{project.paymentTerms}}
                    </p>
                </div>
            </div>
        </section>

        <!-- ITEMS -->
        <section class="items-section">
            <table>
                <thead>
                    <tr>
                        <th>Description of Works / Products</th>
                        <th style="width: 100px;">Qty</th>
                        <th style="width: 150px;">Unit Price</th>
                        <th style="width: 150px; text-align: right;">Total (QAR)</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each lineItems}}
                    <tr>
                        <td class="item-desc">
                            <b>{{this.title}}</b>
                            <small>{{this.description}}</small>
                        </td>
                        <td>{{this.qty}}</td>
                        <td>{{this.unitPrice}}</td>
                        <td style="text-align: right;"><b>{{this.lineTotal}}</b></td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </section>

        <!-- TERMS & TOTALS -->
        <section class="bottom-grid">
            <div class="conditions-box">
                <h4>Terms &amp; Exclusions</h4>
                <ul>
                    <li>Prices are inclusive of 5% VAT (unless stated otherwise).</li>
                    <li>This quotation is valid for {{validDays}} days from the date of issue.</li>
                    <li>Delivery/Completion timeline is subject to site readiness or stock availability.</li>
                    <li>Standard warranty of {{warrantyPeriod}} applies to all hardware/services mentioned.</li>
                </ul>
            </div>
            <div>
                <table class="totals-table">
                    <tr>
                        <td>Subtotal</td>
                        <td>{{subtotal}}</td>
                    </tr>
                    <tr>
                        <td>VAT (5%)</td>
                        <td>{{vatAmount}}</td>
                    </tr>
                    <tr>
                        <td>Discount ({{discountPercent}}%)</td>
                        <td>-{{discount}}</td>
                    </tr>
                    <tr class="grand-total">
                        <td>Total QAR</td>
                        <td>{{grandTotal}}</td>
                    </tr>
                </table>
            </div>
        </section>

        <!-- APPROVAL -->
        <section class="approval-section">
            <div style="font-size: 13px; max-width: 400px; color: var(--secondary);">
                <p><b>Acceptance:</b></p>
                <p>By signing this quotation, the client agrees to the terms and pricing mentioned above.</p>
            </div>
            <div class="client-sign-box">
                <div style="height: 60px;"></div>
                <div class="sign-line">Client Signature &amp; Company Stamp</div>
                <div style="font-size: 10px; margin-top: 5px; opacity: 0.6;">Date: ____/____/20__</div>
            </div>
        </section>

        <!-- FOOTER -->
        <footer class="contact-footer">
            {{company.website}} • {{company.address}} • Thank you for the opportunity to quote.
        </footer>
    </div>

</body>

</html>