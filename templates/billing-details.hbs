<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Billing Details - GCC Corporate Standard</title>
    <style>
        :root {
            --primary: #0f172a;
            --secondary: #64748b;
            --accent: #0891b2;
            --border: #e2e8f0;
            --card-bg: #ffffff;
            --section-bg: #f8fafc;
            --success: #10b981;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', -apple-system, system-ui, sans-serif;
        }

        body {
            background: #ffffff;
            color: var(--primary);
            line-height: 1.6;
        }

        .billing-wrapper {
            width: 100%;
            background: #fff;
        }

        .billing-header {
            padding: 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border);
        }

        .billing-header h1 {
            font-size: 24px;
            font-weight: 800;
            color: var(--primary);
            letter-spacing: -0.5px;
        }

        .status-pill {
            padding: 6px 16px;
            background: #ecfeff;
            color: var(--accent);
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .billing-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            padding: 30px 40px;
            background: var(--section-bg);
        }

        .billing-card {
            background: var(--card-bg);
            padding: 24px;
            border-radius: 16px;
            border: 1px solid var(--border);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }

        .billing-card h3 {
            font-size: 13px;
            text-transform: uppercase;
            color: var(--secondary);
            margin-bottom: 18px;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .billing-card h3::before {
            content: '';
            width: 4px;
            height: 16px;
            background: var(--accent);
            border-radius: 4px;
        }

        .data-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            font-size: 14px;
        }

        .data-label {
            color: var(--secondary);
            font-weight: 500;
        }

        .data-value {
            font-weight: 600;
            color: var(--primary);
        }

        .bank-details {
            background: var(--primary);
            color: #fff;
            padding: 24px;
            border-radius: 16px;
            grid-column: span 2;
        }

        .bank-details h3 {
            color: #94a3b8;
            border-bottom: 1px solid #334155;
            padding-bottom: 10px;
        }

        .bank-grid {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 20px;
            margin-top: 15px;
        }

        .bank-item small {
            display: block;
            color: #94a3b8;
            font-size: 11px;
            text-transform: uppercase;
            margin-bottom: 4px;
        }

        .bank-item span {
            font-family: 'JetBrains Mono', monospace;
            font-size: 14px;
            letter-spacing: 0.5px;
        }

        .table-wrap {
            padding: 30px 40px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            text-align: left;
            padding: 12px;
            color: var(--secondary);
            font-size: 12px;
            border-bottom: 2px solid var(--border);
        }

        td {
            padding: 16px 12px;
            border-bottom: 1px solid var(--border);
            font-size: 14px;
        }

        .total-summary {
            margin-top: 30px;
            width: 320px;
            margin-left: auto;
        }

        .grand-total-row {
            background: var(--section-bg);
            padding: 15px;
            border-radius: 12px;
            margin-top: 10px;
            display: flex;
            justify-content: space-between;
            font-size: 18px;
            font-weight: 800;
            color: var(--accent);
        }

        .billing-footer {
            padding: 40px;
            text-align: center;
            border-top: 1px solid var(--border);
        }

        .qr-placeholder {
            width: 80px;
            height: 80px;
            background: #eee;
            margin: 0 auto 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            font-size: 10px;
            color: #aaa;
        }

        @media (max-width: 768px) {

            .billing-grid,
            .bank-grid {
                grid-template-columns: 1fr;
            }

            .bank-details {
                grid-column: span 1;
            }
        }
    </style>
</head>

<body>

    <div class="billing-wrapper">
        <!-- HEADER -->
        <header class="billing-header">
            <div>
                <h1>Billing Details</h1>
                <p style="font-size: 13px; color: var(--secondary);">Reference: {{refNumber}}</p>
            </div>
            <div class="status-pill">{{paymentStatus}}</div>
        </header>

        <!-- BENTO GRID -->
        <section class="billing-grid">
            <!-- Client Info -->
            <div class="billing-card">
                <h3>Bill To</h3>
                <div class="data-row"><span class="data-label">Entity:</span> <span
                        class="data-value">{{client.companyName}}</span></div>
                <div class="data-row"><span class="data-label">TRN/VAT:</span> <span
                        class="data-value">{{client.trn}}</span></div>
                <div class="data-row"><span class="data-label">Contact:</span> <span
                        class="data-value">{{client.contactName}}</span></div>
                <div class="data-row"><span class="data-label">Email:</span> <span
                        class="data-value">{{client.email}}</span></div>
            </div>

            <!-- Payment Terms -->
            <div class="billing-card">
                <h3>Terms &amp; Schedule</h3>
                <div class="data-row"><span class="data-label">Issue Date:</span> <span
                        class="data-value">{{issueDate}}</span></div>
                <div class="data-row"><span class="data-label">Due Date:</span> <span
                        class="data-value">{{dueDate}}</span></div>
                <div class="data-row"><span class="data-label">Payment Term:</span> <span
                        class="data-value">{{paymentTerm}}</span></div>
                <div class="data-row"><span class="data-label">Method:</span> <span
                        class="data-value">{{paymentMethod}}</span></div>
            </div>

            <!-- Bank Details Card (Full Width) -->
            <div class="bank-details">
                <h3>Settlement Instructions (Local/International)</h3>
                <div class="bank-grid">
                    <div class="bank-item">
                        <small>Bank Name</small>
                        <span>{{bank.name}}</span>
                    </div>
                    <div class="bank-item">
                        <small>Beneficiary Name</small>
                        <span>{{bank.beneficiary}}</span>
                    </div>
                    <div class="bank-item">
                        <small>SWIFT / BIC</small>
                        <span>{{bank.swift}}</span>
                    </div>
                    <div class="bank-item" style="grid-column: span 2;">
                        <small>IBAN Number</small>
                        <span>{{bank.iban}}</span>
                    </div>
                    <div class="bank-item">
                        <small>Currency</small>
                        <span>{{bank.currency}}</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- TRANSACTION TABLE -->
        <section class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Service/Product Description</th>
                        <th>Qty</th>
                        <th>Rate</th>
                        <th>VAT %</th>
                        <th style="text-align:right">Total (QAR)</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each items}}
                    <tr>
                        <td>{{this.name}}</td>
                        <td>{{this.qty}}</td>
                        <td>{{this.rate}}</td>
                        <td>{{this.vatPercent}}</td>
                        <td style="text-align:right"><b>{{this.total}}</b></td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>

            <!-- TOTALS SUMMARY -->
            <div class="total-summary">
                <div class="data-row"><span class="data-label">Subtotal</span> <span
                        class="data-value">{{subtotal}}</span></div>
                <div class="data-row"><span class="data-label">Taxable Amount (5%)</span> <span
                        class="data-value">{{taxableAmount}}</span></div>
                <div class="data-row"><span class="data-label">Total VAT</span> <span
                        class="data-value">{{totalVAT}}</span></div>
                <div class="grand-total-row">
                    <span>Amount Due</span>
                    <span>{{grandTotal}}</span>
                </div>
            </div>
        </section>

        <!-- FOOTER -->
        <footer class="billing-footer">
            <div class="qr-placeholder">E-PAY QR</div>
            <p style="font-size: 13px; font-weight: 600; color: var(--primary);">Secure Payment Reference: {{uniqueID}}
            </p>
            <p style="font-size: 12px; color: var(--secondary); margin-top: 5px;">Please include the Invoice Reference
                in your bank transfer remarks.</p>
            <div style="margin-top: 25px; font-size: 11px; color: #cbd5e1;">
                شكراً لتعاونكم معنا • Thank you for your business
            </div>
        </footer>
    </div>

</body>

</html>